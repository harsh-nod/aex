{
  "$schema": "https://raw.githubusercontent.com/microsoft/vscode/master/extensions/theme-seti/syntaxes/plist.tmLanguage.schema.json",
  "name": "AEX",
  "scopeName": "source.aex",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#check-operators"
    },
    {
      "include": "#arrow"
    },
    {
      "include": "#tool-call"
    },
    {
      "include": "#type-annotation"
    },
    {
      "name": "string.quoted.double.aex",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.aex",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "constant.numeric.aex",
      "match": "\\b-?[0-9]+(?:\\.[0-9]+)?\\b"
    },
    {
      "name": "constant.language.boolean.aex",
      "match": "\\b(true|false)\\b"
    },
    {
      "name": "variable.parameter.aex",
      "match": "\\$[A-Za-z0-9_.-]+"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.aex",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.aex",
          "match": "\\b(agent|goal|use|deny|need|budget|do|make|check|confirm|return)\\b"
        }
      ]
    },
    "check-operators": {
      "patterns": [
        {
          "name": "keyword.operator.aex",
          "match": "\\b(has|is valid diff|touches only|does not include|has citations|before)\\b"
        }
      ]
    },
    "arrow": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.aex",
          "match": "->"
        }
      ]
    },
    "tool-call": {
      "patterns": [
        {
          "name": "entity.name.function.aex",
          "match": "\\b[a-z][a-z0-9]*\\.[a-z][a-z0-9]*\\b"
        }
      ]
    },
    "type-annotation": {
      "patterns": [
        {
          "name": "support.type.aex",
          "match": ":\\s*(str|int|float|bool|object|list\\[[^\\]]*\\])"
        }
      ]
    }
  },
  "fileTypes": [
    "aex"
  ],
  "uuid": "c9c6d8a4-4a16-4d3a-8b52-9a6a0e5c3fa1"
}
