{
  "name": "@aex-lang/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "scripts": {
    "build": "npm run build -w @aex-lang/parser && npm run build -w @aex-lang/validator && npm run build -w @aex-lang/runtime && npm run build -w @aex-lang/cli && npm run build -w @aex-lang/openai-agents && npm run build -w @aex-lang/mcp-gateway && npm run build -w @aex-lang/langgraph",
    "dev": "npm run dev -w @aex-lang/cli",
    "lint": "npm run lint -w @aex-lang/cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli": "npm run test -w @aex-lang/cli",
    "docs:dev": "npm run dev -w @aex-lang/website",
    "docs:build": "npm run build -w @aex-lang/website"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "eslint": "^9.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
